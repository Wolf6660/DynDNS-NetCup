APP_PORT=8080
APP_SIGNING_SECRET=please-change-this-signing-secret
APP_TOKEN_MASTER_KEY=please-change-this-token-master-key
APP_BASE_ZONE=example.de

# DynDNS-Betriebsart
# netcup_webspace = oeffentlicher Update-Endpunkt liegt auf dem Netcup-Webspace
# local_api = oeffentlicher Update-Endpunkt laeuft direkt im Docker auf extra API-Port
DYNDNS_MODE=netcup_webspace

# Optionale Test-URL fuer das Webinterface
# Wird nur fuer die Funktion "Update testen" in der Admin-Oberflaeche verwendet.
# Bei local_api z.B.:
# DYNDNS_UPDATE_URL=http://IP-Docker-Server:API-PORT/api/update.php
# Bei netcup_webspace z.B.:
# DYNDNS_UPDATE_URL=https://example.de/api/update.php
# Oder wenn die Dateien in einem Unterordner liegen, den kompletten Pfad zur update.php eintragen.
DYNDNS_UPDATE_URL=

# Lokaler Docker-Betrieb
# Diese Werte werden verwendet, wenn Netcup-Zugangsdaten nur lokal im Docker-Host liegen sollen.
NETCUP_ENDPOINT=https://ccp.netcup.net/run/webservice/servers/endpoint.php?JSON
NETCUP_CUSTOMER_NUMBER=
NETCUP_API_KEY=
NETCUP_API_PASSWORD=
NETCUP_CLIENT_REQUEST_ID_PREFIX=DockerDynDNS
API_PORT=24081

# Netcup-Webspace-Betrieb
# Diese Werte sind nur noetig, wenn der oeffentliche Update-Endpunkt auf dem Netcup-Webspace laeuft.
# Wenn du nur die lokale Docker-API verwendest, kannst du diesen Block leer lassen.
NETCUP_SERVER_ENDPOINT=https://ccp.netcup.net/run/webservice/servers/endpoint.php?JSON
NETCUP_SERVER_CUSTOMER_NUMBER=
NETCUP_SERVER_API_KEY=
NETCUP_SERVER_API_PASSWORD=
NETCUP_SERVER_SIGNING_SECRET=please-change-this-server-signing-secret

# FTP-Upload
# Standard fuer dieses Projekt. In den meisten Faellen brauchst du diesen Block.
UPLOAD_METHOD=ftp
UPLOAD_REMOTE_JSON_PATH=/data/dyndns_config.json
UPLOAD_REMOTE_SIG_PATH=/data/dyndns_config.sig
FTP_HOST=
FTP_PORT=21
FTP_SSL=false
FTP_USER=
FTP_PASS=
FTP_PASSIVE=true

# WebDAV-Upload
# Nur noetig, wenn du statt FTP bewusst WebDAV verwenden willst.
# Wenn du FTP nutzt, kann dieser Block leer bleiben.
WEBDAV_JSON_URL=
WEBDAV_SIG_URL=
WEBDAV_USER=
WEBDAV_PASS=
